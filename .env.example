# ┌─────────────────────────────────────────────────────┐
# │  Browser Pool Service - 环境变量配置                   │
# │  cp .env.example .env 后根据角色修改                   │
# └─────────────────────────────────────────────────────┘

# ── 网络 ──────────────────────────────────────────────

# 本机内网 IP
HOST_IP=192.168.1.100

# Master 节点 IP（Worker 需要填写）
MASTER_IP=192.168.1.100

# ── 角色 ──────────────────────────────────────────────

# master | worker
ROLE=master

# ── Master 配置 ───────────────────────────────────────

# 全局最大并发 session 数
MAX_GLOBAL_SESSIONS=10

# 默认 session TTL（秒）
TTL_DEFAULT=1800

# 最大 session TTL（秒）
TTL_MAX=7200

# SQLite 数据库路径
DB_PATH=/data/browser-pool.db

# Profile 数据存储目录（master 端 tar.gz 存放）
PROFILE_STORAGE_DIR=/data/profiles

# ── Worker 配置 ───────────────────────────────────────

# Master API 地址
MASTER_URL=http://${MASTER_IP}:9000

# 节点唯一标识
NODE_ID=node-1

# 节点引擎类型: cloakbrowser | browserless
NODE_ENGINE=cloakbrowser

# Browserless 认证 token（仅 engine=browserless 时需要）
NODE_TOKEN=

# 节点对外可达地址（Master 回调用）
# CloakBrowser: http://<HOST_IP>:8080
# Browserless:  http://<HOST_IP>:3000
NODE_ADVERTISE_URL=http://${HOST_IP}:8080

# 每节点最大并发
MAX_NODE_SESSIONS=5

# Worker 内部 sync 端口
WORKER_PORT=9001

# ── 数据同步 ──────────────────────────────────────────

# NFS 模式（设置后启用，Worker 直接读写 NFS 而非 HTTP 传输）
# 留空 = HTTP 模式
NFS_PROFILES_DIR=

# Worker 本地 profile 解压目录（共享给 CBM 的 /data/profiles）
LOCAL_PROFILES_DIR=/shared-profiles

# ── Browserless 专用（docker-compose.browserless.yml）──

# Browserless 认证 token
BL_TOKEN=browserless-token

# Browserless 最大并发（同时设置 CONCURRENT 和 MAX_NODE_SESSIONS）
MAX_SESSIONS=5
